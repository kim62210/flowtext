{
  "name": "flowtext-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "check": "pnpm coverage && pnpm typecheck && pnpm build",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup packages/flowtext/src/index.ts --format esm,cjs --dts --out-dir packages/flowtext/dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "yoga-layout": "^3.2.1"
  }
}
